# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub

# Your GitHub Personal Access Token (with repo read access)
GITHUB_TOKEN=your_github_personal_access_token_here

# Your GitHub username
GITHUB_USERNAME=your_github_username

# The name of your private repository
GITHUB_REPO=your_private_repo_name

# The path to the CSV file inside your repo (e.g. data/residents_data.csv)
GITHUB_FILE_PATH=residents_data.csv
